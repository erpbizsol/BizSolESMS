@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
<link href="~/assets/css/filter.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="~/assets/script/MailConfiguration.js"></script>
<section class="breadcrumbs1" id="txtheaderdiv" style="display:none">
    <div class="container-fluid" style="">
        <div class="fix-header">
            <div class="row">
                <div class="col-md-6 col-6">
                    <div class="icon-tab">
                        <a class="btn-icon me-1" onclick="Save()" title="Save" id="txtsave"><i class='bx bx-save'></i></a>
                        <a class="btn-icon btn-danger" id="btnBack" onclick="BackMaster()" title="Back"><i class='bx bx-arrow-back'></i></a>
                    </div>
                </div>
                <div class="col-md-6 col-6">
                    <div id="tab1" class="tabSec tab active">NEW</div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="container">
    <div class="mt-3" id="txtListpage">
        <div class="row">
            <div class="col-sm-12 text-end">
                <label></label>
                <button type="button" class="btn btn-success btn-height" title="CREATE NEW" onclick="Create()">CREATE NEW</button>
            </div>
        </div>
        <div class="card-body mt-2" id="txtTable">
            <div class="table-wrapper fixed-height-table">
                <table id="table" class="fixed-width-table table">
                    <thead id="table-header">
                    </thead>
                    <tbody id="table-body">
                    </tbody>
                </table>
            </div>
            <!-- Paginator -->
            <div class="paginator" id="paginator-table">
            </div>
        </div>
    </div>
    <div id="txtCreatepage" style="display:none;">
        <div class="card shadow-sm" style="background-color:#e9e9ef">
            <div class="tabs">
                <div class="row p-1">
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-3 col-sm-6">
                                <input type="hidden" id="hfCode" value="0" />
                                <label for="txtForType" class="col-form-label-sm fw-bold">For Type</label> <span class="text-danger">*</span>
                                <select id="txtForType" class="box_border form-control form-control-sm">
                                    <option value="Daily Operation Summary">Daily Operation Summary</option>
                                </select>
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtSMSType" class="col-form-label-sm fw-bold">SMS Type</label> <span class="text-danger">*</span>
                                <select id="txtSMSType" class="box_border form-control form-control-sm">
                                    <option value="Email">Email</option>
                                    <option value="WhatsApp">WhatsApp</option>
                                </select>
                            </div>
                            <div class="col-md-3 col-sm-6" id="dvEmail" style="display:block">
                                <label for="txtEmail" class="col-form-label-sm fw-bold">Email (With ; Separates)</label> <span class="text-danger">*</span>
                                <textarea id="txtEmail" class="box_border form-control form-control-sm" autocomplete="off" maxlength="500" placeholder="Please Enter Email"></textarea>
                            </div>
                            <div class="col-md-3 col-sm-6" id="dvWhatsApp" style="display:none">
                                <label for="txtWhatsAppNo" class="col-form-label-sm fw-bold">Mobile No (With , Separates And 91)</label> <span class="text-danger">*</span>
                                <textarea id="txtWhatsAppNo" class="box_border form-control form-control-sm" autocomplete="off" maxlength="500" placeholder="Please Enter WhatsApp No"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/assets/js/filter.js"></script>

