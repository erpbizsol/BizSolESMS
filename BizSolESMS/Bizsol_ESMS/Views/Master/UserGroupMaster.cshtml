@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="~/assets/css/filter.css" rel="stylesheet" />
<script src="~/assets/script/UserGroupMaster.js"></script>
<section class="breadcrumbs1" id="txtheaderdiv" style="display:none">
    <div class="container-fluid" style="">
        <div class="fix-header">
            <div class="row">
                <div class="col-md-6 col-6">
                    <div class="icon-tab">
                        <a class="btn-icon me-1" id="btnSave" title="Save"><i class='bx bx-save'></i></a>
                        <a class="btn-icon btn-danger" id="btnBack" title="Back"><i class='bx bx-arrow-back'></i></a>
                    </div>
                </div>
                <div class="col-md-6 col-6">
                    <div id="tab1" class="tabSec tab active">NEW</div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="container">
<div id="tblUserMaster" class="sm-table mt-3">
    <div class="row">
        <div class="col-sm-12 text-end">
            <label></label>
            @* <button type="button" class="btn btn-primary btn-height">DOWNLOAD</button> *@
            <button type="button" class="btn btn-success btn-height" title="CREATE NEW" onclick="Create()">CREATE NEW</button>
        </div>
    </div>
    <div class="card-body mt-2" id="txtUserGroupMaster">
        <div class="table-wrapper fixed-height-table">
            <table id="table" class="fixed-width-table table">
                <thead id="table-header">
                </thead>
                <tbody id="table-body">
                </tbody>
            </table>
        </div>
        <div class="paginator" id="paginator-table"> 
        </div>
    </div>
</div>
<div id="FrmUserMaster" style="display:None">
    
        <div class="card shadow-sm" style="background-color:#e9e9ef">
            <div class="tabs">
              @*   <div class="tab-header">
                    <div id="tab1" class="tab active" style="color:white"></div>
                </div> *@
                <div class="row p-1">
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-4 col-sm-6">
                                <label for="txtGroupName" class="col-form-label-sm fw-bold">Group Name<span class="text-danger">*</span> </label>
                                <input type="text" id="txtGroupName" class="box_border form-control form-control-sm" placeholder="Enter Group Name" autocomplete="off" maxlength="30">
                                <input type="hidden" id="hfCode" class="box_border form-control form-control-sm" autocomplete="off" maxlength="20" value="0">
                            </div>
                            <div class="col-md-4 col-sm-6">
                                <label for="ddlGroupType" class="col-form-label-sm fw-bold">Type<span class="text-danger">*</span></label>
                                <select id="ddlGroupType" name="ddlGroupType" class="box_border form-control form-control-sm" autocomplete="off">
                                    <option value="A" selected>Administrator</option>
                                    <option value="U">User</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
               @*  <div class="row m-2">
                    <div class="col-md-12" style="margin-top: 30px !important;">
                        <button class="btn btn-primary btn-height" title="Save" id="btnSave">Save</button>
                        <button class="btn btn-danger btn-height" title="Back" id="btnBack">Back</button>
                    </div>
                </div> *@
            </div>
        </div>

</div>
</div>
<script src="~/assets/js/filter.js"></script>
