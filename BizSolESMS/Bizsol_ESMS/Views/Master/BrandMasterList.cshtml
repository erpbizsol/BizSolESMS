@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
<link href="~/assets/css/filter.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="~/assets/script/brandmaster.js"></script>
<section class="breadcrumbs1" id="txtheaderdiv" style="display:none">
    <div class="container-fluid" style="">
        <div class="fix-header">
            <div class="row">
                <div class="col-md-6 col-6">
                    <div class="icon-tab">
                        <a class="btn-icon me-1" onclick="Save()" id="txtbtnSave" title="Save"><i class='bx bx-save'></i></a>
                        <a class="btn-icon btn-danger" id="btnBack" onclick="BackMaster()" title="Back"><i class='bx bx-arrow-back'></i></a>
                    </div>
                </div>
                <div class="col-md-6 col-6">
                    <div id="tab1" class="tabSec tab active">NEW</div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="container">
    <div class="sm-table mt-3" id="txtListpage">
        <div class="row">
            <div class="col-sm-12 text-end">
                <label></label>
                <button type="button" class="btn btn-primary btn-height" title="DOWNLOAD" onclick="DataExport()">DOWNLOAD</button>
                <button type="button" class="btn btn-success btn-height" title="CREATE NEW" onclick="CreateBrandMaster()">CREATE NEW</button>
            </div>
        </div>
        <div class="card-body mt-2" id="txtbrandtable">
            <div class="table-wrapper fixed-height-table">
                <table id="table" class="fixed-width-table table">
                    <thead id="table-header">
                    </thead>
                    <tbody id="table-body">
                    </tbody>
                </table>
            </div>
            <!-- Paginator -->
            <div class="paginator" id="paginator-table">
            </div>
        </div>
    </div>
    <div id="txtCreatepage" style="display:none;">
        <div class="card shadow-sm" style="background-color:#e9e9ef">
            <div class="tabs">
                <div class="row p-1">
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-3">
                                <label for="txtUOM" class="col-form-label-sm fw-bold">
                                    Brand Name <span class="text-danger">*</span>
                                </label>
                                <input type="hidden" value="0" id="hftextCode" />
                                <input type="text" id="txtBrandName" name="txtBrandName" autocomplete="off" class="form-control form-control-sm box_border" placeholder="Brand Name" maxlength="50">
                            </div>
                            <div class="col-md-3">
                                <label for="ddlImportFormat" class="col-form-label-sm fw-bold">
                                    Import Format <span class="text-danger">*</span>
                                </label>
                                <datalist id="ddlImportFormat"></datalist>
                                <input list="ddlImportFormat" id="txtImportFormat" name="txtImportFormat" autocomplete="off" class="form-control form-control-sm box_border" placeholder="Import Format">
                            </div>
                            <div class="col-md-3">
                                <label for="ddlBarcodeType" class="col-form-label-sm fw-bold">
                                    Barcode Type <span class="text-danger">*</span>
                                </label>
                                <select id="ddlBarcodeType" name="ddlBarcodeType" class="form-control form-control-sm box_border">
                                    <option value="">Select Barcode Type</option>
                                    <option value="UPI">UPI</option>
                                    <option value="UPIHERO">UPI HERO</option>
                                    <option value="NoBarcode">No Barcode</option>
                                    <option value="SameasPartCode">SameAsPartCode</option>
                                    <option value="DifferentAsPartCode">DifferentAsPartCode</option>

                                </select>
                            </div>
                            <div class="col-md-3" style="margin-top:34px;">
                                <input type="checkbox" id="txtPicklistNo" name="txtPicklistNo" class="box_border" checked />

                                <label for="txtPicklistNo" class="col-form-label-sm fw-bold">
                                    Is PicklistNo mandatory <span class="text-danger">*</span>
                                </label>
                            </div>
                            @* <div class="col-md-2" style="margin-top: 30px !important;">
                            <button class="btn btn-primary btn-height" title="Save" onclick="Save()" id="txtbtnSave">Save</button>
                            <button class="btn btn-danger btn-height" title="Back" onclick="BackMaster()">Back</button>
                            </div> *@
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/assets/js/filter.js"></script>



