@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="~/assets/script/prefixconfiguration.js"></script>
<section class="breadcrumbs1" id="txtheaderdiv" >
    <div class="container-fluid" style="">
        <div class="fix-header">
            <div class="row">
                <div class="col-md-6 col-6">
                    <div class="icon-tab">
                        <a class="btn-icon me-1" onclick="Save()" id="txtsave" title="Save"><i class='bx bx-save'></i></a>
                        @* <a class="btn-icon btn-danger" id="btnBack" onclick="BackMaster()" title="Back"><i class='bx bx-arrow-back'></i></a> *@
                    </div>
                </div>
                <div class="col-md-6 col-6">
                    <div id="tab1" class="tabSec tab active">NEW</div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="container">
<div id="txtCreatepage">
    <div class="card shadow-sm" style="background-color:#e9e9ef">
        <div class="tabs">
           @*  <div class="tab-header">
                <div id="tab1" class="tab active" style="color:white">EDIT</div>
            </div> *@
            <div class="row p-1">
                <div class="col-md-12">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="row">
                                <div class="col-md-4 col-sm-6">
                                    <label for="txtMRNNo" class="col-form-label-sm fw-bold">Pre.MRN No</label><span class="text-danger">*</span>
                                    <input type="text" id="txtMRNNo" class="box_border form-control form-control-sm" autocomplete="off" maxlength="20" placeholder="Pre.MRN No">
                                </div>
                                <div class="col-md-4 col-sm-6">
                                    <label for="txtOrderNo" class="col-form-label-sm fw-bold">Pre.Order No</label><span class="text-danger">*</span>
                                    <input type="text" id="txtOrderNo" class="box_border form-control form-control-sm" autocomplete="off" maxlength="20" placeholder="Pre.Order No">
                                </div>
                                <div class="col-md-4 col-sm-6">
                                    <label for="txtChallanNo" class="col-form-label-sm fw-bold">Pre.Challan No</label><span class="text-danger">*</span>
                                    <input type="text" id="txtChallanNo" autocomplete="off" class="form-control form-control-sm box_border" maxlength="20"  placeholder="Pre.Challan No">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
           @*  <div class="row mt-2">
                <div class="col-md-12 text-end">
                    <button class="btn btn-primary btn-height" title="Save" onclick="Save()" id="txtsave">Save</button>
                </div>
            </div> *@
        </div>
    </div>
</div>
</div>



