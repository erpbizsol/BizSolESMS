@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
<link href="~/assets/css/filter.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/exceljs/dist/exceljs.min.js"></script>
<script src="~/assets/script/DispatchBoxValidation.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
<script src="~/assets/js/autosuggestion.js"></script>
<section class="breadcrumbs1" id="txtheaderdiv" style="display:none">
    <div class="container-fluid" style="">
        <div class="fix-header">
            <div class="row">
                <div class="col-md-6 col-6">
                    <div class="icon-tab">
                        <a class="btn-icon btn-danger" id="btnBack" onclick="Back()" title="Back"><i class='bx bx-arrow-back'></i></a>
                    </div>
                </div>
                <div class="col-md-6 col-6">
                    <div id="tab1" class="tabSec tab active"></div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="container">
    <div class="row" style="margin-left:-6px;margin-top:10px;display:block;" id="dvSearch">
        <div class="col-md-3  col-sm-6">
            <label for="txSearch" class="col-form-label-sm fw-bold">
                Search
            </label>
            <input type="text" id="txtSearch" name="txtSearch" autocomplete="off" class="form-control form-control-sm box_border" placeholder="Search.." maxlength="50">
        </div>
    </div>
    <div class="row m-1" sstyle="display:none" id="UnloadingTable1">
        <div class="col-sm-12 text-end m-2">
            <button type="button" class="btn btn-primary btn-height" title="Print Gate Pass" onclick="GetGatePassManual()">Manual Dispatch</button>
            <button type="button" class="btn btn-primary btn-height" title="Print Gate Pass" onclick="GetGatePass()">Gate Pass</button>
        </div>
        <div class="card-body">
            <div class="table-wrapper fixed-height-table">
                <table id="table1" class="fixed-width-table table">
                    <thead id="table-header1">
                    </thead>
                    <tbody id="table-body1">
                    </tbody>
                </table>
            </div>
            <div class="paginator" id="paginator-table1">
            </div>
        </div>
    </div>
    <div id="UnloadingForm" style="display:none">
        <div class="card shadow-sm textCreatepage"  style="background-color:#e9e9ef;">
            <div class="tabs">
                <div class="row p-1">
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-3 col-sm-6">
                                <label for="txtOrderNo" class="col-form-label-sm fw-bold">Order No</label>
                                <input type="text" id="txtOrderNo" disabled class="box_border form-control form-control-sm" autocomplete="off" placeholder="Order No..">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtPartyName" class="col-form-label-sm fw-bold">Party Name</label>
                                <input type="text" disabled id="txtPartyName" class="box_border form-control form-control-sm" autocomplete="off" placeholder="Party Name..">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtAddress" class="col-form-label-sm fw-bold">Address</label>
                                <input type="text" disabled id="txtAddress" class="box_border form-control form-control-sm" autocomplete="off" placeholder="Address..">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-wrapper fixed-height-table">
                <table id="table" class="fixed-width-table table">
                    <thead id="table-header">
                    </thead>
                    <tbody id="table-body">
                    </tbody>
                </table>
            </div>
            <div class="paginator" id="paginator-table">
            </div>
        </div>
    </div>
    <div id="EditForm" style="display:none">
        <div class="card shadow-sm" style="background-color:#e9e9ef;">
            <div class="tabs">
                <div class="row p-1">
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-3 col-sm-6">
                                <audio id="SuccessVoice" style="display: none;"><source src="~/assets/audio/voice.mp3" type="audio/mpeg" /></audio>
                                <audio id="BoxNoVoice" style="display: none;"><source src="~/assets/audio/BoxNoVoice.mp3" type="audio/mpeg" /></audio>
                                <label for="txtVehicleNo" class="col-form-label-sm fw-bold">Vehicle No.</label> <span class="text-danger">*</span>
                                <input type="text" id="txtVehicleNo" onkeyup="convertToUppercase(this)" class="box_border form-control form-control-sm" maxlength="50" autocomplete="off" placeholder="Vehicle No..">
                                <ul id="txtVehicleNoList" class="AutoSuggestion-list"></ul>
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtInvoiceNo" class="col-form-label-sm fw-bold">Invoice No</label> <span class="text-danger">*</span>
                                <input type="text" id="txtInvoiceNo" class="box_border form-control form-control-sm" maxlength="50" autocomplete="off" placeholder="Invoice No..">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtDriverName" class="col-form-label-sm fw-bold">Driver Name</label> <span class="text-danger">*</span>
                                <input type="text" id="txtDriverName" class="box_border form-control form-control-sm" maxlength="50" autocomplete="off" placeholder="Driver Name..">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtDriverNumber" class="col-form-label-sm fw-bold">Driver Contact Number</label> <span class="text-danger">*</span>
                                <input type="text" id="txtDriverNumber" class="box_border form-control form-control-sm Phone" maxlength="10" autocomplete="off" placeholder="Driver Contact Number..">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtLorryMeter" class="col-form-label-sm fw-bold">Lorry Meter Reading</label> <span class="text-danger">*</span>
                                <input type="text" id="txtLorryMeter" class="box_border form-control form-control-sm Phone" maxlength="7" autocomplete="off" placeholder="Lorry Meter Reading..">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtUserName" class="col-form-label-sm fw-bold">Scan By</label> 
                                <input type="text" disabled id="txtUserName" class="box_border form-control form-control-sm" autocomplete="off" placeholder="Scan By..">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtScanProduct" class="col-form-label-sm fw-bold">Scan Product</label> <span class="text-danger">*</span>
                                <input type="text" id="txtScanProduct" class="box_border form-control form-control-sm" autocomplete="off" maxlength="200" placeholder="Scan Product.." onfocus="this.select()">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-wrapper fixed-height-table">
                <table id="EditTable" class="fixed-width-table table">
                    <thead id="EditTable-header">
                    </thead>
                    <tbody id="EditTable-body">
                    </tbody>
                </table>
            </div>
            <div class="paginator" id="paginator-EditTable">
            </div>
        </div>
    </div>
    <div id="ManualForm" style="display:none">
        <div class="card shadow-sm" style="background-color:#e9e9ef;">
            <div class="tabs">
                <div class="row p-1">
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-3 col-sm-6">
                                <label for="txtManualVehicleNo" class="col-form-label-sm fw-bold">Vehicle No.</label> <span class="text-danger">*</span>
                                <input type="text" id="txtManualVehicleNo" onkeyup="convertToUppercase(this)" class="box_border form-control form-control-sm" maxlength="50" autocomplete="off" placeholder="Vehicle No..">
                                <ul id="txtManualVehicleNoList" class="AutoSuggestion-list"></ul>
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtManualDriverName" class="col-form-label-sm fw-bold">Driver Name</label> <span class="text-danger">*</span>
                                <input type="text" id="txtManualDriverName" class="box_border form-control form-control-sm" maxlength="50" autocomplete="off" placeholder="Driver Name..">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtManualDriverNumber" class="col-form-label-sm fw-bold">Driver Contact Number</label> <span class="text-danger">*</span>
                                <input type="text" id="txtManualDriverNumber" class="box_border form-control form-control-sm Phone" maxlength="10" autocomplete="off" placeholder="Driver Contact Number..">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtManualLorryMeter" class="col-form-label-sm fw-bold">Lorry Meter Reading</label> <span class="text-danger">*</span>
                                <input type="text" id="txtManualLorryMeter" class="box_border form-control form-control-sm Phone" maxlength="7" autocomplete="off" placeholder="Lorry Meter Reading..">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtManualUserName" class="col-form-label-sm fw-bold">Made By</label> <span class="text-danger">*</span>
                                <input type="text" disabled id="txtManualUserName" class="box_border form-control form-control-sm" autocomplete="off" placeholder="Made By..">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label for="txtManualOrderNo" class="col-form-label-sm fw-bold">Order No</label> <span class="text-danger">*</span>
                                <select id="txtManualOrderNo" class="form-control form-control-sm box_border" multiple style="width: 300px;" placeholder="Select locations..">
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div> 
        <div class="card-body" id="tblManual" style="display:none">
            <div class="table-wrapper fixed-height-table">
                <table id="ManualTable" class="fixed-width-table table">
                    <thead id="ManualTable-header">
                    </thead>
                    <tbody id="ManualTable-body">
                    </tbody>
                </table>
            </div>
            <div class="paginator" id="paginator-ManualTable">
            </div>
        </div>
    </div>
    <div class="modal position-absolute" id="staticBackdrop" style="padding-top:30px;" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-body">
                    <div class="modal-header tab-header" style="background-color:#033764">
                        <level style="color:white">Print Gate Pass</level>
                        <button type="button" class="close modal-close btn-sm" aria-label="Close" onclick="CloseModal()"><span aria-hidden="true">x</span></button>
                    </div>
                    <div class="row" style="margin-top:10px;">
                        <div class="col-md-12">
                            <div class="row">
                                <div class="col-md-6 col-sm-6">
                                    <label for="txtModalVehicleNo" class="col-form-label-sm fw-bold">Vehicle No</label> <span class="text-danger">*</span>
                                    <input type="text" id="txtModalVehicleNo" onkeyup="convertToUppercase(this)" class="box_border form-control form-control-sm" autocomplete="off" placeholder="Vehicle No..">
                                    <ul id="txtModalVehicleNoList" class="AutoSuggestion-list"></ul>
                                </div>
                                <div class="col-md-6 col-sm-6">
                                    <label for="txtDate" class="col-form-label-sm fw-bold">Date</label> <span class="text-danger">*</span>
                                    <input type="text"  id="txtDate" class="box_border form-control form-control-sm" autocomplete="off" placeholder="Date..">
                                </div> 
                                <div class="col-md-2 col-sm-6">
                                    <button type="button" id="btnModelShow" class="btn btn-primary btn-height" title="Show" onclick="ShowData()">
                                        Show
                                    </button>
                                </div> 
                            </div>
                        </div>
                    </div>
                    <div class="row p-2">
                        <div class="card-body">
                            <div class="table-wrapper fixed-height-table">
                                <table id="PrintTable" class="fixed-width-table table">
                                    <thead id="PrintTable-header">
                                    </thead>
                                    <tbody id="PrintTable-body">
                                    </tbody>
                                </table>
                            </div>
                            <div class="paginator" id="paginator-PrintTable">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
<div id="overlay" class="overlay"></div>
<div id="toast" class="toast-container"></div>
<script src="~/assets/js/filter.js"></script>