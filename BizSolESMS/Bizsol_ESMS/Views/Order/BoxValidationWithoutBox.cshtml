@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
<link href="~/assets/css/filter.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<link href="https://gitcdn.github.io/bootstrap-toggle/2.2.2/css/bootstrap-toggle.min.css" rel="stylesheet">
<script src="https://gitcdn.github.io/bootstrap-toggle/2.2.2/js/bootstrap-toggle.min.js"></script>
<script src="~/assets/script/BoxValidationWithoutBox.js"></script>

<style>
    .bv-page-wrapper {
        padding: 16px;
    }

    /* List card */
    .bv-list-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.08);
        overflow: hidden;
    }
    .bv-list-card-header {
        background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
        padding: 14px 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .bv-list-card-header .bv-icon {
        width: 36px;
        height: 36px;
        background: rgba(255,255,255,.18);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 16px;
        flex-shrink: 0;
    }
    .bv-list-card-header h5 {
        margin: 0;
        color: #fff;
        font-size: 15px;
        font-weight: 600;
        letter-spacing: .3px;
    }
    .bv-list-card-header .bv-subtitle {
        color: rgba(255,255,255,.75);
        font-size: 12px;
        margin: 0;
    }
    .bv-list-card-body {
        padding: 16px;
    }

    /* Top bar */
    .bv-top-bar {
        background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
        padding: 10px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-radius: 0 0 0 0;
        box-shadow: 0 2px 8px rgba(13,71,161,.25);
    }
    .bv-back-btn {
        background: rgba(255,255,255,.18);
        border: none;
        color: #fff;
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        cursor: pointer;
        transition: background .2s;
        flex-shrink: 0;
    }
    .bv-back-btn:hover { background: rgba(255,255,255,.32); }
    .bv-page-title {
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: .8px;
        text-transform: uppercase;
    }

    /* Info card */
    .bv-info-card {
        background: #fff;
        border-radius: 0 0 12px 12px;
        box-shadow: 0 4px 12px rgba(0,0,0,.08);
        padding: 14px 20px;
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        align-items: center;
        margin-bottom: 0;
    }
    .bv-info-field {
        display: flex;
        flex-direction: column;
        min-width: 150px;
    }
    .bv-info-field label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: #6c757d;
        margin-bottom: 4px;
    }
    .bv-value-badge {
        background: #eef2ff;
        color: #1a73e8;
        font-size: 13px;
        font-weight: 600;
        padding: 5px 12px;
        border-radius: 6px;
        border: 1px solid #c7d7f9;
        white-space: nowrap;
        display: inline-block;
    }

    /* Detail card */
    .bv-detail-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.08);
        overflow: hidden;
        margin-top: 14px;
    }
    .bv-detail-card-header {
        background: #f8f9fa;
        border-bottom: 2px solid #e9ecef;
        padding: 12px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .bv-detail-title {
        font-size: 13px;
        font-weight: 700;
        color: #343a40;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .bv-detail-title i { color: #1a73e8; }
    .bv-detail-card-body {
        padding: 14px;
    }
</style>

<!-- Top bar: back button + title (hidden until validation starts) -->
<section id="txtheaderdiv" style="display:none">
    <div class="bv-top-bar">
        <button class="bv-back-btn" onclick="Back()" title="Back">
            <i class="bx bx-arrow-back"></i>
        </button>
        <span class="bv-page-title"><i class="fa fa-circle-check me-2"></i>Box Validation</span>
        <div style="width:34px"></div>
    </div>

    <!-- Info bar: picklist, vehicle, scan product -->
    <div class="bv-info-card">
        <audio id="SuccessVoice" style="display:none"><source src="~/assets/audio/voice.mp3" type="audio/mpeg" /></audio>
        <!-- hidden inputs used by JS -->
        <input type="text" id="txtCode"       class="d-none" autocomplete="off">
        <input type="text" id="txtPickListNo" class="d-none" autocomplete="off">
        <input type="text" id="txtVehicleNo"  class="d-none" autocomplete="off">
        <input type="checkbox" id="txtIsManual" class="d-none">

        <div class="bv-info-field d-none">
            <label><i class="fa fa-list-ol me-1"></i>PickList No</label>
            <span class="bv-value-badge" id="lblPickListNo">—</span>
        </div>

        <div class="bv-info-field">
            <label><i class="fa fa-truck me-1"></i>LR Number</label>
            <span class="bv-value-badge" id="lblVehicleNo">—</span>
        </div>

        <div class="bv-info-field" style="min-width:200px">
            <label><i class="fa fa-barcode me-1"></i>Scan Product <span class="text-danger">*</span></label>
            <input type="text" id="txtScanProduct"
                   class="form-control form-control-sm box_border"
                   autocomplete="off"
                   placeholder="Scan product here..."
                   onfocus="this.select()">
        </div>
    </div>
</section>

<div class="bv-page-wrapper">

    <!-- Pending validations list -->
    <div id="UnloadingTable1" style="display:none" class="bv-list-card">
        <div class="bv-list-card-header">
            <div class="bv-icon"><i class="fa fa-boxes-stacked"></i></div>
            <div>
                <h5>Pending Validations</h5>
                <p class="bv-subtitle">Select a picklist to begin box validation</p>
            </div>
        </div>
        <div class="bv-list-card-body">
            <div class="table-wrapper fixed-height-table">
                <table id="table1" class="fixed-width-table table ssm-table">
                    <thead id="table-header1"></thead>
                    <tbody id="table-body1"></tbody>
                </table>
            </div>
            <div class="paginator" id="paginator-table1"></div>
        </div>
    </div>

    <!-- Validation detail grid -->
    <div id="UnloadingTable" style="display:none" class="bv-detail-card">
        <div class="bv-detail-card-header">
            <span class="bv-detail-title">
                <i class="fa fa-table-list"></i> Validation Detail
            </span>
            <button class="btn btn-sm btn-primary d-none" id="btnAutoUpdate" title="Auto update received qty">
                <i class="fa fa-bolt me-1"></i> Accept All
            </button>
        </div>
        <div class="bv-detail-card-body">
            <div class="table-wrapper fixed-height-table">
                <table id="table" class="fixed-width-table table ssm-table">
                    <thead id="table-header"></thead>
                    <tbody id="table-body"></tbody>
                </table>
            </div>
            <div class="paginator" id="paginator-table"></div>
        </div>
    </div>

</div>

<div id="overlay" class="overlay"></div>
<div id="toast" class="toast-container"></div>

<script src="~/assets/js/filter.js"></script>
