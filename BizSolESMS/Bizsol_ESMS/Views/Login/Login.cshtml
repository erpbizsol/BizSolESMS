@{
    Layout = "~/Views/Shared/_Layout1.cshtml";
}
    <title>Login ESMS</title>
    <link href="~/assets/css/esms-login.css" rel="stylesheet" />

    <div class="login-containers card">
        <div class="text-center Esms-login-logo">
        <img src="~/assets/images/final_logo-circle.jpg" class="Esms-logo" />
    </div>

        @* <h4 class="center">
            <img style="height:40px;vertical-align:bottom" src="~/assets/images/bizsol-logo-small.gif" />
             <font style="font-size: xx-large;line-height: 1.3;"> <span style="color:#ef6c00;">B</span><span style="color: #569252;">iz</span><span style="color:#ef6c00;">S</span><span style="color:#569252;">o</span><span style="color:#ef6c00;">l</span> </font>
            e-SMS
            <span class="text-right"><i class="fa fa-lock fa-2x"></i></span>
        </h4> *@
       
        <form>
        <div class="mt-2">
                <label for="txtCompanyCode" class="form-label login-form-text">Company Code</label>
            <input id="txtCompanyCode" name="CompanyCode" class="login-test-field form-control login-form-text" placeholder="Enter Company Code" type="text" required autocomplete="off">
            </div>
        <input type="button" class="login-test-field btn btn-primary login-form-text mt-3" id="btnValidateCompany" value="Proceed" />
            <div id="userCredentials" style="display: none;">
                <div class="mt-2"id="txtU">
                <label for="txtUserID" class="form-label login-form-text">User ID</label>
                <input id="txtUserID" name="UserID" class="login-test-field form-control login-form-text" placeholder="Enter User ID" type="text" required autocomplete="off">
                </div>
                <div class="mt-2" id="txtP">
                <label for="txtPassword" class="form-label login-form-text">Password</label>
                <input id="txtPassword" name="Password" class="login-test-field form-control login-form-text" placeholder="Enter Password" autocomplete="off" type="password" required>
                </div>
                <input type="button" class="login-test-field btn btn-primary login-form-text mt-3" id="btnProceed" value="Login" />
                
            </div>
            <div class="mt-2 text-end" style="font-size:15px;">
                <a href="" id="txtProofOfDelivery">Click here for POD</a>
            </div>
        </form>
    </div>

    <!-- Modal for Users with Empty IsActive -->
    <div class="modal fade" id="usersEmptyIsActiveModal" tabindex="-1" aria-labelledby="usersEmptyIsActiveModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="usersEmptyIsActiveModalLabel">Active Users</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="noUsersMessage" style="display: none;">
                        <p class="text-center text-muted">No active users found.</p>
                    </div>
                    <div id="usersEmptyIsActiveTable" style="display: none;">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered">
                                <thead>
                                    <tr>
                                        <th>S.No</th>
                                        <th>User ID</th>
                                        <th>User Name</th>
                                        <th>Mobile No</th>
                                        <th>Email ID</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="usersEmptyIsActiveTableBody">
                                    <!-- Table rows will be populated by JavaScript -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts should be loaded after the DOM elements -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Bootstrap JS Bundle (includes Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/Script/Login.js"></script>





